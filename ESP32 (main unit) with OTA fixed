  if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
}

void playActiveBuzzerChime(bool turningOn) {
  if (commsFaultActive) return; 
  if (turningOn) {
    digitalWrite(buzzer_pin, HIGH); delay(60);
    digitalWrite(buzzer_pin, LOW);  delay(60);
    digitalWrite(buzzer_pin, HIGH); delay(60);
    digitalWrite(buzzer_pin, LOW);  delay(60);
    digitalWrite(buzzer_pin, HIGH); delay(140);
    digitalWrite(buzzer_pin, LOW);
  } else {
    digitalWrite(buzzer_pin, HIGH); delay(120);
    digitalWrite(buzzer_pin, LOW);  delay(80);
    digitalWrite(buzzer_pin, HIGH); delay(120);
    digitalWrite(buzzer_pin, LOW);
  }
}

