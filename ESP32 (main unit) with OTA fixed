                          if(nSsid.length() > 0 && nSsid != "null") { pEdit.begin("water-cfg", false); pEdit.putString("b3_ssid", nSsid); pEdit.end(); configNeedsReboot = true; logEvent("[WIFI] Slot 4 SSID Updated"); } 
                      }
                      Firebase.RTDB.deleteNode(&fbdo, basePath + "/control/setWifiSlot4_SSID");
                  }
                  if (Firebase.RTDB.get(&fbdo, basePath + "/control/setWifiSlot4_Pass")) {
                      if (fbdo.dataType() == "string") {
                          String nPass = fbdo.stringData(); nPass.replace("\"", ""); nPass.trim();
                          if(nPass.length() > 0 && nPass != "null") { pEdit.begin("water-cfg", false); pEdit.putString("b3_pass", nPass); pEdit.end(); configNeedsReboot = true; logEvent("[WIFI] Slot 4 Pass Updated"); } 
                      }
                      Firebase.RTDB.deleteNode(&fbdo, basePath + "/control/setWifiSlot4_Pass");
                  }
                  break;

              case 4:
                  if (true) {
                      FirebaseJson slotsJson;
                      pEdit.begin("water-cfg", true);
                      slotsJson.set("slot1", pEdit.getString("w1_ssid", "Empty"));
                      slotsJson.set("slot2", pEdit.getString("b1_ssid", "Empty"));
                      slotsJson.set("slot3", pEdit.getString("b2_ssid", "Empty"));
                      slotsJson.set("slot4", pEdit.getString("b3_ssid", "Empty"));
                      pEdit.end();
                      Firebase.RTDB.updateNode(&fbdo, basePath + "/networkSlots", &slotsJson);
                  }
                  
                  if (configNeedsReboot) {
                      logEvent("[SYSTEM] -> Rebooting to apply new WiFi credentials...");
                      Firebase.RTDB.setString(&fbdo, basePath + "/telemetry/log", "[SYSTEM] Rebooting to apply new WiFi...");
                      delay(2000);
                      WiFi.disconnect(true, true); 
                      ESP.restart();
                  }
                  break;

              case 5:
                  if (Firebase.RTDB.getBool(&fbdo, basePath + "/control/otaTrigger")) {
                      if (fbdo.boolData() == true) {
                          
                          String downloadUrl = "";
                          if (Firebase.RTDB.getString(&fbdo, basePath + "/control/otaUrl")) {
                              downloadUrl = fbdo.stringData(); 
                              downloadUrl.trim();
                          }
                          
                          if (downloadUrl.length() > 10 && downloadUrl.indexOf("http") != -1) { 
                              
                              otaInProgress = true; 
                              digitalWrite(relay_pump, RELAY_OFF); 
                              digitalWrite(led_relay_status, LOW); 
                              digitalWrite(led_signal_status, LOW);
                              pumpActive = false;
                              
                              // --- CRITICAL FIX: PUSH OTA MODE TO DASHBOARD AND WAIT FOR TX ---
                              Firebase.RTDB.setBool(&fbdo, basePath + "/state/otaMode", true);
                              Firebase.RTDB.setString(&fbdo, basePath + "/telemetry/log", "[OTA] Contacting GitHub...");
                              delay(2000); // 2 full seconds to guarantee packet transmission!
                              
                              logEvent("[OTA] Freeing memory for GitHub connection...");
                              
                              Firebase.RTDB.deleteNode(&fbdo, basePath + "/control/otaTrigger"); 
                              Firebase.RTDB.deleteNode(&fbdo, basePath + "/control/otaUrl");
                              
                              downloadUrl.replace("github.com", "raw.githubusercontent.com");
                              downloadUrl.replace("/blob/", "/");
                              downloadUrl.replace("/raw/refs/heads/", "/");
                              downloadUrl.replace("/refs/heads/", "/");
                              downloadUrl.replace("/raw/", "/");
                              downloadUrl.replace("/edit/", "/");
                              downloadUrl.replace("/tree/", "/");
                              
                              fbdo.stopWiFiClient(); 
                              fbdo.clear(); 
                              delay(500);
                              
                              WiFiClientSecure client; 
                              client.setInsecure(); 
                              
                              httpUpdate.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
                              httpUpdate.rebootOnUpdate(false); 
                              
                              // --- CRITICAL FIX: DATA-BASED LED TOGGLING ---
                              // Defeats Flash memory CPU freezing for beautiful bright pulses
                              httpUpdate.onProgress([](int current, int total) {
                                  int percent = (total > 0) ? (current * 100 / total) : (current / 20000);
                                  bool ledState = (percent % 2) == 0; // Toggle state every 1% of download
                                  
                                  digitalWrite(led_0_24, ledState ? HIGH : LOW);
                                  digitalWrite(led_25_49, ledState ? HIGH : LOW);
                                  digitalWrite(led_50_74, ledState ? HIGH : LOW);
                                  digitalWrite(led_75_100, ledState ? HIGH : LOW);
                                  
                                  digitalWrite(led_relay_status, LOW);
                                  digitalWrite(led_signal_status, LOW);
                              });

                              t_httpUpdate_return ret = httpUpdate.update(client, downloadUrl);

                              digitalWrite(led_0_24, LOW);
                              digitalWrite(led_25_49, LOW);
                              digitalWrite(led_50_74, LOW);
                              digitalWrite(led_75_100, LOW);

                              Preferences pOtaMem;
                              pOtaMem.begin("water-cfg", false);
                              
                              if (ret == HTTP_UPDATE_OK) {
                                  pOtaMem.putInt("ota_flag", 1); 
                                  pOtaMem.end();
                                  
                                  for (int i = 0; i < 6; i++) {
                                      digitalWrite(buzzer_pin, HIGH);
                                      delay(250);
                                      digitalWrite(buzzer_pin, LOW);
                                      delay(250);
                                  }
                                  ESP.restart();
                              } else {
                                  pOtaMem.putInt("ota_flag", 2); 
                                  pOtaMem.end();
                                  delay(3000); 
                                  ESP.restart(); 
                              }
                          }
                      }
                  }
                  break;
          }
          
          slowPollState++;
          if(slowPollState > 5) slowPollState = 0;
      }
    }
    vTaskDelay(50 / portTICK_PERIOD_MS); 
  }
}

