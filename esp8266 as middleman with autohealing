#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>
#include <ESP8266WiFi.h>

// --- STRICT ESP8266 PIN ASSIGNMENTS ---
#define CE_PIN D2  // MOVED TO D2! D4 is the onboard LED.
#define CSN_PIN D8

// --- EXTERNAL DIAGNOSTIC LED PIN ASSIGNMENTS ---
#define TANK_LED D1                
#define ONBOARD_LED LED_BUILTIN // This is D4 on NodeMCU/Wemos              

// Initialize radio
RF24 radio(CE_PIN, CSN_PIN);
const byte address[6] = "WTR01";

unsigned long lastTankPacketTime = 0;
const unsigned long timeoutDuration = 2000; 
unsigned long lastTankBlinkTime = 0;
bool tankLedState = false;

bool wasHardwareFaulty = true; 
unsigned long lastRadioInitAttempt = 0;
uint32_t lastKnownPacketId = 0; 

// 32-BYTE PERFECT FIT STRUCTURE 
struct __attribute__((packed)) AdvancedPayload {
  float verifiedDistance;
  float raw1;
  float raw2;
  uint32_t packetId;
  char nanoLog[13]; 
  bool tankRadioOk;
  bool middlemanRadioOk;
  bool espRadioOk;
};
AdvancedPayload relayPackage;

bool initializeRadio() {
  if (radio.begin()) {
    // EXACT MIRROR OF ESP32 HUB CONFIGURATION
    radio.setChannel(125);   
    radio.setAutoAck(true);  // CRITICAL FIX: Matches ESP32 and Nano to prevent hardware packet drops
    
    // --- MASSIVE DISTANCE BOOSTERS ---
    // Max out the hardware retries (15 retries, 4000us delay between them) to punch through walls
    radio.setRetries(15, 15); 
    // Set power amplifier to HIGH instead of MAX to reduce electrical noise and improve stability
    radio.setPALevel(RF24_PA_HIGH); 
    
    radio.setDataRate(RF24_250KBPS);     
    radio.setCRCLength(RF24_CRC_16); 
    
    radio.openReadingPipe(1, address);
    radio.openWritingPipe(address);
    
    radio.flush_rx();
    radio.flush_tx();
    radio.startListening();
    
    return true;
  }
  return false;
}

void setup() {
  Serial.begin(115200);
  
  // Shut down WiFi modem to stop 2.4GHz noise blinding the nRF24
  WiFi.mode(WIFI_OFF);
  WiFi.forceSleepBegin();
  
  delay(2000); 
  
  Serial.println(F("\n\n======================================="));
  Serial.println(F("[REPEATER] Initializing ESP8266 Middleman..."));
  Serial.println(F("======================================="));

  pinMode(TANK_LED, OUTPUT);
  pinMode(ONBOARD_LED, OUTPUT);
  
  digitalWrite(TANK_LED, LOW); 
  digitalWrite(ONBOARD_LED, HIGH); // HIGH turns OFF the ESP8266 onboard LED

  if (initializeRadio()) {
      Serial.println(F("[SUCCESS] -> Auto-Healing Relay Active."));
      wasHardwareFaulty = false;
  } else {
      Serial.println(F("[ERROR] -> Check SPI wiring (CE to D2, CSN to D8)!"));
  }
  
  // Initialize slightly in the past to prevent instant false positive
  lastTankPacketTime = millis() - 5000; 
}

void loop() {
  unsigned long currentMillis = millis();
  bool isRadioHardwareHealthy = radio.isChipConnected();

  // 1. AUTO-HEALING WATCHDOG
  if (!isRadioHardwareHealthy) {
    if (!wasHardwareFaulty) {
        Serial.println(F("[ERROR] -> Radio disconnected! Powering down SPI to recover..."));
        wasHardwareFaulty = true;
        lastRadioInitAttempt = currentMillis; 
    }
    
    if (currentMillis - lastRadioInitAttempt >= 3000) {
        lastRadioInitAttempt = currentMillis;
        if (initializeRadio()) {
            Serial.println(F("[SUCCESS] -> Radio recovered from power crash. Memory Reloaded!"));
            wasHardwareFaulty = false;
        }
    }
  } 
  // --- NEW FIX: SILICON LOCKUP WATCHDOG ---
  // If the chip is plugged in, but we haven't heard a single packet in 60 seconds,
  // the nRF24L01 internal logic has frozen due to static/noise. Force a reboot!
  else if (currentMillis - lastTankPacketTime > 60000) {
      Serial.println(F("======================================="));
      Serial.println(F("[SILICON FREEZE ALARM] -> 60 Seconds of pure silence!"));
      Serial.println(F(" -> The nRF24L01 internal receiver has locked up."));
      Serial.println(F(" -> Executing forced software flush and restart..."));
      Serial.println(F("======================================="));
      initializeRadio();
      lastTankPacketTime = currentMillis; // reset to prevent rapid-fire rebooting
  }
  else {
    // 2. READ PROCESS
    if (!wasHardwareFaulty && radio.available()) {
      radio.read(&relayPackage, sizeof(relayPackage)); 
      
      // --- NEW FIX: SAFE LED BYPASS ---
      // We removed the "return;" statements here so the loop ALWAYS reaches the LED logic.
      
      // THE ANTI-STATIC GARBAGE TRAP
      if (relayPackage.packetId == 0) {
         radio.flush_rx(); 
      }
      // SMART DUPLICATE FILTER
      // Only filters duplicates if they arrive within 500ms
      else if (relayPackage.packetId == lastKnownPacketId && (currentMillis - lastTankPacketTime < 500)) {
         radio.flush_rx();
      }
      // VALID PACKET PROCESSING
      else {
         lastKnownPacketId = relayPackage.packetId;
         lastTankPacketTime = currentMillis; 
         digitalWrite(TANK_LED, LOW); 

         // --- EVENT-DRIVEN LED FLASH (ON) ---
         // Turns the onboard ESP8266 LED ON the exact moment a packet is received
         digitalWrite(ONBOARD_LED, LOW); 

         relayPackage.middlemanRadioOk = true;

         strncpy(relayPackage.nanoLog, "Via Repeater", 12);
         relayPackage.nanoLog[12] = '\0'; 

         Serial.print(F("[RELAY] Captured Packet ID: ")); 
         Serial.print(relayPackage.packetId);
         Serial.print(F(" | Dist: "));
         Serial.print(relayPackage.verifiedDistance);
         Serial.println(F("cm | HW: OK"));

         radio.stopListening();
         
         // Wait exactly 45ms to avoid airwave collisions with Roof Tank
         delay(45); 

         radio.flush_tx();  
         
         radio.write(&relayPackage, sizeof(relayPackage));
         
         Serial.println(F("        -> Packet successfully boosted to ESP32 Hub."));

         // MUST flush RX *before* startListening to prevent deleting incoming data
         radio.flush_rx();
         radio.startListening();

         // --- EVENT-DRIVEN LED FLASH (OFF) ---
         // Turns the onboard ESP8266 LED OFF immediately after relaying
         digitalWrite(ONBOARD_LED, HIGH);
      }
    }
  }

  // 3. DIAGNOSTIC LEDS
  bool isTankOnline = (currentMillis - lastTankPacketTime <= timeoutDuration);
  
  if (isTankOnline) {
      // Tank is ONLINE: Ensure External Tank Offline LED is OFF
      digitalWrite(TANK_LED, LOW);
  } else {
      // Tank is OFFLINE: Onboard LED stays OFF, External D1 LED blinks steadily
      if (currentMillis - lastTankBlinkTime >= 500) {
          lastTankBlinkTime = currentMillis;
          tankLedState = !tankLedState;
          digitalWrite(TANK_LED, tankLedState ? HIGH : LOW);
      }
  }

  // 4. HEARTBEAT DIAGNOSTIC
  static unsigned long lastHeartbeatPrint = 0;
  if (currentMillis - lastHeartbeatPrint >= 5000) {
      lastHeartbeatPrint = currentMillis;
      if (isRadioHardwareHealthy && !wasHardwareFaulty) {
          Serial.println(F("[SYSTEM] Middleman actively scanning channel 125 for Roof Tank..."));
      }
  }
}
