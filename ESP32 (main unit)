  }
  prefs.end();

  if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
  Serial.println(F("\n========================================================================"));
  Serial.println(F("   ESP32 TERMINAL - MULTI-NODE SYSTEM WITH ULTRA-FAST SYNC              "));
  Serial.println(F("========================================================================"));
  Serial.print(F("   -> Assigned Machine ID: ")); Serial.println(custom_dev_id);
  Serial.print(F("   -> Loaded Tank Depth:   ")); Serial.print(bucket_empty_distance); Serial.println(F(" cm"));
  Serial.print(F("   -> Loaded Full Level:   ")); Serial.print(bucket_full_distance); Serial.println(F(" cm"));
  if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);

  if (!radio.begin()) {
    logEvent("[STARTUP ERROR] -> nRF24L01 Radio Hardware Missing!");
  } else {
    radio.setChannel(125);            
    radio.setAutoAck(true);           
    radio.openReadingPipe(1, address);
    radio.setPALevel(RF24_PA_HIGH);     
    radio.setDataRate(RF24_250KBPS);     
    radio.setCRCLength(RF24_CRC_16);   
    radio.startListening();           
    radio.flush_rx();                  
    logEvent("[SYSTEM STATUS] -> Radio Online. Power Level MAX.");
  }
  
  lastPacketTime = millis();
  
  xTaskCreatePinnedToCore(firebaseSyncTask, "FirebaseSync", 32768, NULL, 1, NULL, 1);
}

void loop() {
  if (!radio.isChipConnected()) {
    triggerCommsSafetyShutdown(1);
    delay(10); 
    return; 
  }

  unsigned long currentMillis = millis();
  
  static int lastButtonState = HIGH;
  static int buttonState = HIGH;
  static unsigned long lastDebounceTime = 0;
  static unsigned long btnDownTime = 0;
  static bool longPressFired = false;
  static unsigned long lastTapTime = 0;
  static int tapCount = 0;

  int reading = digitalRead(button_manual);

  if (reading != lastButtonState) {
    lastDebounceTime = currentMillis;
  }

  if ((currentMillis - lastDebounceTime) > 50) {
    if (reading != buttonState) {
      buttonState = reading;

      if (buttonState == LOW) {
        btnDownTime = currentMillis;
        longPressFired = false;
      } else {
        unsigned long pressDuration = currentMillis - btnDownTime;

        if (!longPressFired && pressDuration > 50) { 
          if (currentMillis - lastTapTime > 2000) {
            tapCount = 0;
          }
          tapCount++;
          lastTapTime = currentMillis;

          if (tapCount >= 3) {
            logEvent("[FACTORY RESET] -> 3 Clicks Detected! Erasing WiFi but saving Config...");
            digitalWrite(relay_pump, RELAY_OFF); 
            digitalWrite(led_relay_status, HIGH);
            WiFi.disconnect(true, true); 
            delay(500);
            
            Preferences pRescue;
            pRescue.begin("water-cfg", false);
            String savedId = pRescue.getString("dev_id", "DEVICE_001");
            float savedEmpty = pRescue.getFloat("empty_dist", 26.0);
            float savedFull = pRescue.getFloat("full_dist", 7.0);
            pRescue.end();
            
            WiFiManager wm; 
            wm.resetSettings(); 
            Preferences pWipe; 
            pWipe.begin("water-cfg", false); 
            pWipe.clear(); 
            pWipe.end();
            
            Preferences pRestore;
            pRestore.begin("water-cfg", false);
            pRestore.putString("dev_id", savedId);
            pRestore.putFloat("empty_dist", savedEmpty);
            pRestore.putFloat("full_dist", savedFull);
            pRestore.end();
            
            delay(1000); 
            ESP.restart();      
          }
        }
      }
    }
  }
  lastButtonState = reading;

  bool physicalPumpTrigger = false;
  if (buttonState == LOW && !longPressFired) {
    if (currentMillis - btnDownTime >= 3000) { 
      longPressFired = true;
      physicalPumpTrigger = true; 
      tapCount = 0; 
    }
  }

  if (!commsFaultActive) {
    if (physicalPumpTrigger || webCommandPending) {
      bool wasWebTrigger = webCommandPending; 
      
      if (webCommandPending) {
        pumpActive = webCommandTarget;
        webCommandPending = false;
      } else {
        pumpActive = !pumpActive;
      }

      if (pumpActive) {
        automationBypassed = false; 
        digitalWrite(relay_pump, RELAY_ON);
        playActiveBuzzerChime(true);
        pumpOnReminderMillis = currentMillis;
        
        if (wasWebTrigger) logEvent("[WEB COMMAND] -> Pump ON via Cloud.");
        else logEvent("[MANUAL BUTTON] -> Pump ON via 3-Second Hold.");
        
      } else {
        if (currentWaterPercent <= 25.0) {
          automationBypassed = true;
          logEvent("[USER OVERRIDE] -> Pump OFF below 25%. Auto-fill LOCKED.");
        }
        digitalWrite(relay_pump, RELAY_OFF);
        digitalWrite(led_relay_status, LOW);
        playActiveBuzzerChime(false);
        
        if (wasWebTrigger) logEvent("[WEB COMMAND] -> Pump OFF via Cloud.");
        else logEvent("[MANUAL BUTTON] -> Pump OFF via 3-Second Hold.");
      }
    }
  } else {
    webCommandPending = false; 
  }

  if (radio.available()) {
    radio.read(&receivePackage, sizeof(receivePackage));
    receivePackage.nanoLog[12] = '\0'; 

    String incomingNanoText = String(receivePackage.nanoLog);
    incomingNanoText.trim();

    String tnkStat = receivePackage.tankRadioOk ? "OK" : "FAULT";
    String midStat = receivePackage.middlemanRadioOk ? "OK" : "FAULT";
    String espStat = radio.isChipConnected() ? "OK" : "FAULT";

    // --- ENHANCED: SILENT ECHO CATCHER FOR EXPLICIT MIDDLEMAN PROOF ---
    if (receivePackage.packetId == lastKnownPacketId && incomingNanoText.indexOf("Repeater") != -1) {
        repeaterHealthStatus = incomingNanoText;
        lastRepeaterHeardMillis = currentMillis;
        
        if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
        latestNanoLog = "Path: Direct Link | RPT: " + repeaterHealthStatus + "\nRaw S1: " + String(receivePackage.raw1, 1) + "cm | Raw S2: " + String(receivePackage.raw2, 1) + "cm\nFinal Output: " + String(receivePackage.verifiedDistance, 1) + "cm";
        
        // Prints undeniable proof that the Middleman caught the signal and forwarded it successfully
        latestHardwareLog = "RADIO HEALTH DIAGNOSTICS:\nTank Nano: " + tnkStat + "\nMiddleman: " + midStat + " [Echo Active]\nESP32 Hub: " + espStat;
        if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
        return; 
    }

    if (receivePackage.packetId > lastKnownPacketId) {
      
      if (expectedPacketId > 0 && receivePackage.packetId > expectedPacketId) {
          packetsMissed += (receivePackage.packetId - expectedPacketId);
      }
      packetsReceived++;
      expectedPacketId = receivePackage.packetId + 1;

      lastKnownPacketId = receivePackage.packetId;
      lastPacketTime = currentMillis; 
      
      if (incomingNanoText.indexOf("Repeater") != -1) {
          repeaterHealthStatus = incomingNanoText;
          lastRepeaterHeardMillis = currentMillis;
      } else {
          incomingNanoText = "Direct Link";
          midStat = "N/A (Bypassed)"; 
      }

      if (commsFaultActive) {
        commsFaultActive = false;
        digitalWrite(led_signal_status, LOW); 
        logEvent("[SYSTEM RECOVERY] -> Air Signal Restored.");
        
        connectionRecoveryMillis = currentMillis;
        synchronizationWindowActive = true;
      }

      currentWaterCm = receivePackage.verifiedDistance;
      currentS1Cm = receivePackage.raw1;
      currentS2Cm = receivePackage.raw2;

      if (currentS1Cm <= 0.1 && currentS2Cm <= 0.1) {
          triggerCommsSafetyShutdown(3); 
          return;
      }
      else if (currentWaterCm > 0.1 && currentWaterCm <= 3.0) {
          triggerCommsSafetyShutdown(4);
          return;
      }

      if (currentWaterCm > 0.1) {
        
        float rawTargetPercent = ((bucket_empty_distance - currentWaterCm) / (bucket_empty_distance - bucket_full_distance)) * 100.0;
        if (rawTargetPercent < 0.0) rawTargetPercent = 0.0;
        if (rawTargetPercent > 100.0) rawTargetPercent = 100.0;
        
        if (synchronizationWindowActive) {
            currentWaterPercent = rawTargetPercent; 
            
            if (currentMillis - connectionRecoveryMillis >= 5000) {
                synchronizationWindowActive = false;
                filterInitialized = true;
                logEvent("[FILTER] Recovery window closed. Moving-Average filter processing unlocked.");
            }
        } else {
            if (!filterInitialized) {
                currentWaterPercent = rawTargetPercent;
                filterInitialized = true;
                logEvent("[FILTER] System initialized. Memory baseline locked.");
            } else {
                currentWaterPercent = (rawTargetPercent * 0.12) + (currentWaterPercent * (1.0 - 0.12));
            }
        }

        if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
        latestNanoLog = "Path: " + incomingNanoText + " | RPT: " + repeaterHealthStatus + "\nRaw S1: " + String(currentS1Cm, 1) + "cm | Raw S2: " + String(currentS2Cm, 1) + "cm\nFinal Output: " + String(currentWaterCm, 1) + "cm";
        latestHardwareLog = "RADIO HEALTH DIAGNOSTICS:\nTank Nano: " + tnkStat + "\nMiddleman: " + midStat + "\nESP32 Hub: " + espStat;
        latestSystemLog = "[RX] Tank: " + String(currentWaterPercent, 1) + "%" + "\n>> " + lastSystemEvent;
        if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);

        if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
        Serial.print(F("[RX] S1: ")); Serial.print(currentS1Cm, 1);
        Serial.print(F("cm | S2: ")); Serial.print(currentS2Cm, 1);
        Serial.print(F("cm | Final: ")); Serial.print(currentWaterCm, 1);
        Serial.print(F("cm | Tank: ")); Serial.print(currentWaterPercent, 1); 
        Serial.print(F("% | Path: ")); Serial.println(incomingNanoText);
        if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);

        if (currentWaterPercent > 25.5 && automationBypassed) {
          automationBypassed = false;
          logEvent("[SYSTEM REGULAR] -> Water safe. Automation Re-enabled.");
        }

        if (rawTargetPercent >= 98.0) {
          consecutiveFullReadings++;
        } else if (rawTargetPercent < 90.0) {
          consecutiveFullReadings = 0; 
        }

        if (!commsFaultActive) {
          if (currentWaterPercent <= 25.0 && !pumpActive && !automationBypassed && !synchronizationWindowActive) {
            pumpActive = true;
            digitalWrite(relay_pump, RELAY_ON); playActiveBuzzerChime(true);
            pumpOnReminderMillis = currentMillis; 
            logEvent("[AUTOMATION] -> Level low (<25%). Auto-Fill Active.");
          } 
          else if (consecutiveFullReadings >= 3 && pumpActive) {
            automationBypassed = false; 
            pumpActive = false;
            digitalWrite(relay_pump, RELAY_OFF); digitalWrite(led_relay_status, LOW); 
            playActiveBuzzerChime(false);
            
            String fullLogMsg = "[AUTOMATION] -> Ceiling Hit (3x Verified). Pump shutdown. Tank Depth: " + 
                                String(bucket_empty_distance, 1) + "cm, Full Clearance: " + 
                                String(bucket_full_distance, 1) + "cm.";
            logEvent(fullLogMsg);
            
            consecutiveFullReadings = 0; 
          }

          digitalWrite(led_0_24,   (currentWaterPercent >= 0.0  && currentWaterPercent <= 24.9) ? HIGH : LOW);
          digitalWrite(led_25_49,  (currentWaterPercent >= 25.0 && currentWaterPercent <= 49.9) ? HIGH : LOW);
          digitalWrite(led_50_74,  (currentWaterPercent >= 50.0 && currentWaterPercent <= 74.9) ? HIGH : LOW);
          digitalWrite(led_75_100, (currentWaterPercent >= 75.0 && currentWaterPercent <= 100.0) ? HIGH : LOW);
        }
      }
    }
  }

  // --- ENHANCED: EXPLICIT REPEATER WATCHDOG ---
  // If 5 seconds pass without an echo from the Middleman, it forces the hardware panel to show it is dead.
  if (currentMillis - lastRepeaterHeardMillis > 5000) {
      repeaterHealthStatus = "OFFLINE";
      if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
      if (latestNanoLog.indexOf("Direct Link") != -1) {
          latestNanoLog = "Path: Direct Link | RPT: OFFLINE\nRaw S1: " + String(currentS1Cm, 1) + "cm | Raw S2: " + String(currentS2Cm, 1) + "cm\nFinal Output: " + String(currentWaterCm, 1) + "cm";
      }
      latestHardwareLog = "RADIO HEALTH DIAGNOSTICS:\nTank Nano: " + String(commsFaultActive ? "OFFLINE" : "OK") + "\nMiddleman: OFFLINE\nESP32 Hub: " + String(radio.isChipConnected() ? "OK" : "FAULT");
      if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
  }

  if (currentMillis - lastSignalCalcMillis >= 3000) {
      lastSignalCalcMillis = currentMillis;
      if (packetsReceived > 0 || packetsMissed > 0) {
          float linkHealth = ((float)packetsReceived / (float)(packetsReceived + packetsMissed)) * 100.0;
          packetsReceived = 0;
          packetsMissed = 0;

          if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
          if (linkHealth >= 95.0) {
              currentSignalLabel = "Excellent";
              currentEstDistance = 5;
          } else if (linkHealth >= 80.0) {
              currentSignalLabel = "Good";
              currentEstDistance = 15;
          } else if (linkHealth >= 50.0) {
              currentSignalLabel = "Weak";
              currentEstDistance = 25;
          } else {
              currentSignalLabel = "Critical";
              currentEstDistance = 35;
          }
          if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
      }
  }

  if (currentMillis - lastPacketTime > watchdog_timeout) {
    triggerCommsSafetyShutdown(2);
  } else {
    if (pumpActive && !commsFaultActive) {
      if (currentMillis - prevBlinkMillis >= 300) { 
        prevBlinkMillis = currentMillis; blinkState = !blinkState;
        digitalWrite(led_relay_status, blinkState ? HIGH : LOW);
      }
      if (currentMillis - pumpOnReminderMillis >= 60000) {
        pumpOnReminderMillis = currentMillis;
        logEvent("[SYSTEM] -> Pump motor actively running...");
        playPumpRunningBeep();
      }
    } else if (!otaInProgress) {
      digitalWrite(led_relay_status, LOW);
      blinkState = false;
    }

    if (currentWaterPercent < 25.0 && !pumpActive && !commsFaultActive) {
      if (currentMillis - lowWaterAlertMillis >= 420000) { 
        lowWaterAlertMillis = currentMillis;
        logEvent("[ALERT] -> Water below 25% with auto-fill locked out!");
        playLowWaterWarningBeep();
      }
    } else {
      lowWaterAlertMillis = currentMillis;
    }
  }
  
  delay(10); 
}
