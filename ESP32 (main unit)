void triggerCommsSafetyShutdown(int faultType) {
  if (!commsFaultActive) {
    commsFaultActive = true;
    consecutiveFullReadings = 0; 
    automationBypassed = false; 
    pumpActive = false;
    filterInitialized = false; 
    synchronizationWindowActive = false;
    
    currentWaterPercent = 0.0;
    currentWaterCm = 0.0;
    currentS1Cm = 0.0;
    currentS2Cm = 0.0;

    lastKnownPacketId = 0;
    expectedPacketId = 0;

    if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
    currentSignalLabel = "OFFLINE";
    currentEstDistance = 0;
    latestHardwareLog = "STATUS: NETWORK OFFLINE\nHardware Diags Unavailable.";
    if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
    
    digitalWrite(relay_pump, RELAY_OFF); 
    digitalWrite(led_relay_status, LOW); 
    digitalWrite(led_0_24, LOW); digitalWrite(led_25_49, LOW);
    digitalWrite(led_50_74, LOW); digitalWrite(led_75_100, LOW);
    digitalWrite(buzzer_pin, LOW); 
    
    if (faultType == 1) {
      logEvent("[CRITICAL FAULT] -> LOCAL RECEIVER: ESP32 nRF Chip Unplugged!");
    } else if (faultType == 2) {
      logEvent("[CRITICAL FAULT] -> REMOTE TRANSMITTER: Nano Signal Lost/Power Off!");
      if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
      latestNanoLog = "[TX] SIGNAL LOST\nCheck Nano Power";
      if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);
    } else if (faultType == 3) {
      logEvent("[CRITICAL FAULT] -> TANK SENSORS DEAD OR UNPLUGGED (Reading 0.0cm)");
    } else if (faultType == 4) {
      logEvent("[CRITICAL FAULT] -> EXTREME OVERFLOW RISK! Water hitting sensors. Pump Locked.");
    }
  }

  unsigned long currentMillis = millis();
  if (currentMillis - signalBlinkMillis >= 500) { 
    signalBlinkMillis = currentMillis;
    signalLedState = !signalLedState;
    digitalWrite(led_signal_status, signalLedState ? HIGH : LOW);
  }
}

void firebaseSyncTask(void *pvParameters) {
  WiFi.mode(WIFI_STA);

  esp_wifi_set_protocol(WIFI_IF_STA, WIFI_PROTOCOL_11B);
  WiFi.setTxPower(WIFI_POWER_19_5dBm);

  vTaskDelay(100 / portTICK_PERIOD_MS);

  Preferences p;
  p.begin("water-cfg", true); 
  String w1_ssid = p.getString("w1_ssid", "");
  String w1_pass = p.getString("w1_pass", "");
  String w2_ssid = p.getString("b1_ssid", "");
  String w2_pass = p.getString("b1_pass", "");
  String w3_ssid = p.getString("b2_ssid", "");
  String w3_pass = p.getString("b2_pass", "");
  String w4_ssid = p.getString("b3_ssid", "");
  String w4_pass = p.getString("b3_pass", "");
  p.end();

  SavedAP apList[4];
  int apCount = 0;

  if (w1_ssid.length() > 0) {
      apList[apCount].ssid = w1_ssid; 
      apList[apCount].pass = w1_pass; 
      apCount++;
  }
  if (w2_ssid.length() > 0) {
      apList[apCount].ssid = w2_ssid; 
      apList[apCount].pass = w2_pass; 
      apCount++;
  }
  if (w3_ssid.length() > 0) {
      apList[apCount].ssid = w3_ssid; 
      apList[apCount].pass = w3_pass; 
      apCount++;
  }
  if (w4_ssid.length() > 0) {
      apList[apCount].ssid = w4_ssid; 
      apList[apCount].pass = w4_pass; 
      apCount++;
  }

  logEvent("[WIFI] Initializing Equal Mesh Selector Array with " + String(apCount) + " Hosts.");
  int currentApIndex = 0;
  
  while(WiFi.status() != WL_CONNECTED && apCount > 0) {
      if (apList[currentApIndex].ssid.length() == 0) {
          currentApIndex++;
          if (currentApIndex >= apCount) currentApIndex = 0;
          continue;
      }
      
      logEvent("[WIFI] Connecting to Mesh Node: " + apList[currentApIndex].ssid);
      WiFi.begin(apList[currentApIndex].ssid.c_str(), apList[currentApIndex].pass.c_str());
      
      unsigned long startAttempt = millis();
      while(WiFi.status() != WL_CONNECTED && millis() - startAttempt < 8000) {
          vTaskDelay(500 / portTICK_PERIOD_MS);
      }
      
      if (WiFi.status() != WL_CONNECTED) {
          logEvent("[WIFI] Node unavailable. Shifting pointer mapping...");
          WiFi.disconnect(); 
          vTaskDelay(1000 / portTICK_PERIOD_MS);
          currentApIndex++;
          if (currentApIndex >= apCount) currentApIndex = 0; 
      }
  }
  logEvent("[WIFI] Connected Successfully to Mesh Node: " + WiFi.SSID());

  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;
  auth.user.email = USER_EMAIL;
  auth.user.password = USER_PASSWORD;
  config.token_status_callback = tokenStatusCallback; 
  
  fbdo.setBSSLBufferSize(4096, 1024);
  config.timeout.socketConnection = 10 * 1000;

  Firebase.begin(&config, &auth);

  unsigned long lastFirebaseSync = 0;
  String basePath = "/Devices/" + String(custom_dev_id);

  while(1) {
    if (WiFi.status() != WL_CONNECTED && apCount > 0) {
        logEvent("[WIFI] Connection lost! Scanning 4 Equal Mesh Array Nodes...");
        WiFi.disconnect(); 
        vTaskDelay(1000 / portTICK_PERIOD_MS);
        
        while(WiFi.status() != WL_CONNECTED) {
            if (apList[currentApIndex].ssid.length() == 0) {
                currentApIndex++;
                if (currentApIndex >= apCount) currentApIndex = 0;
                continue;
            }
            
            logEvent("[WIFI] Evaluating Hub Connection at Node: " + apList[currentApIndex].ssid);
            WiFi.begin(apList[currentApIndex].ssid.c_str(), apList[currentApIndex].pass.c_str());
            
            unsigned long startAttempt = millis();
            while(WiFi.status() != WL_CONNECTED && millis() - startAttempt < 8000) {
                vTaskDelay(500 / portTICK_PERIOD_MS); 
            }
            
            if (WiFi.status() == WL_CONNECTED) {
                logEvent("[WIFI] Reconnected successfully to Node: " + WiFi.SSID());
                break; 
            } else {
                logEvent("[WIFI] Node timed out. Rotating layout allocations...");
                WiFi.disconnect(); 
                vTaskDelay(1000 / portTICK_PERIOD_MS);
                currentApIndex++;
                if (currentApIndex >= apCount) currentApIndex = 0; 
            }
        }
    }

    if (WiFi.status() == WL_CONNECTED && Firebase.ready() && millis() - lastFirebaseSync > 1500) {
      lastFirebaseSync = millis();
      heartbeatCounter++;

      String safe_latestSystemLog;
      String safe_latestNanoLog;
      String safe_latestHardwareLog;
      String safe_currentSignalLabel;
      String safe_lastSystemEvent;

      if (coreMutex != NULL) xSemaphoreTakeRecursive(coreMutex, portMAX_DELAY);
      safe_latestSystemLog = latestSystemLog;
      safe_latestNanoLog = latestNanoLog;
      safe_latestHardwareLog = latestHardwareLog;
      safe_currentSignalLabel = currentSignalLabel;
      safe_lastSystemEvent = lastSystemEvent;
      if (coreMutex != NULL) xSemaphoreGiveRecursive(coreMutex);

      FirebaseJson json;
      json.set("deviceStatus/heartbeat", heartbeatCounter);
      json.set("deviceStatus/radioTech", "nrf24l01 (mini)"); 
      json.set("deviceStatus/radioChannel", 125); 
      json.set("deviceStatus/radioDataRate", "250 KBPS");
      json.set("telemetry/waterPercent", currentWaterPercent);
      json.set("telemetry/waterCm", currentWaterCm);
      json.set("telemetry/sensor1Cm", currentS1Cm);
      json.set("telemetry/sensor2Cm", currentS2Cm);
      json.set("telemetry/signalStrength", safe_currentSignalLabel);
      json.set("telemetry/estDistance", currentEstDistance);
      json.set("telemetry/bucketEmptyHeight", bucket_empty_distance);
      json.set("telemetry/bucketFullHeight", bucket_full_distance);
      json.set("telemetry/log", safe_latestSystemLog);
      json.set("telemetry/nanoLog", safe_latestNanoLog); 
      json.set("telemetry/hardwareLog", safe_latestHardwareLog);
      
      json.set("state/fault", commsFaultActive);
      json.set("state/pumpActive", pumpActive);
      json.set("state/automationBypassed", automationBypassed);
      Firebase.RTDB.updateNode(&fbdo, basePath, &json);

      String inboxPath = "/AdminInbox/" + String(custom_dev_id);
      FirebaseJson inboxJson;
      if (commsFaultActive || safe_lastSystemEvent.indexOf("ERROR") != -1) {
          inboxJson.set("status", "⚠️ FAULT DETECTED");
          inboxJson.set("message", safe_lastSystemEvent);
      } else if (safe_lastSystemEvent.indexOf("[OTA]") != -1) {
          inboxJson.set("status", "🔄 OTA ACTIVITY");
          inboxJson.set("message", safe_lastSystemEvent);
      } else {
          inboxJson.set("status", "✅ ONLINE");
          inboxJson.set("message", "System is running normally.");
      }
      Firebase.RTDB.updateNode(&fbdo, inboxPath, &inboxJson);

      if (Firebase.RTDB.getInt(&fbdo, basePath + "/control/triggerId")) {
          int incomingTrigger = fbdo.intData();
          
          if (!initialCloudSyncComplete || lastTriggerId == -1) {
              lastTriggerId = incomingTrigger;
              initialCloudSyncComplete = true;
          } else if (incomingTrigger != lastTriggerId) {
              lastTriggerId = incomingTrigger;
              if (Firebase.RTDB.getBool(&fbdo, basePath + "/control/forceState")) {
                  webCommandTarget = fbdo.boolData();
                  webCommandPending = true; 
              }
          }
      }

      if (Firebase.RTDB.getBool(&fbdo, basePath + "/control/otaTrigger")) {
          if (fbdo.boolData() == true) {
              String downloadUrl = fbdo.stringData();
              downloadUrl.trim(); 
              
              otaInProgress = true; 
              digitalWrite(relay_pump, RELAY_OFF); 
              digitalWrite(led_relay_status, HIGH); 
              pumpActive = false;
              
              logEvent("[OTA] Freeing memory for GitHub connection...");
              Firebase.RTDB.setString(&fbdo, basePath + "/telemetry/log", "[OTA] Contacting GitHub...");
              delay(1000); 
              
              Firebase.RTDB.setBool(&fbdo, basePath + "/control/otaTrigger", false); 
              fbdo.clear(); 
              delay(500);
              
              WiFiClientSecure client;
              client.setInsecure(); 
              client.setTimeout(20000); 
              
              HTTPClient http;
              http.setTimeout(20000); 
              http.begin(client, downloadUrl);
              http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS); 
              http.setUserAgent("ESP32-WaterSystem-OTA"); 
              
              int httpCode = http.GET();
              
              Firebase.begin(&config, &auth);
              unsigned long waitStart = millis();
              while (!Firebase.ready() && millis() - waitStart < 8000) {
                  delay(250);
              }
              
              if (httpCode == HTTP_CODE_OK || httpCode == HTTP_CODE_MOVED_PERMANENTLY || httpCode == 302 || httpCode == 301) {
                  int contentLength = http.getSize();
                  bool canBegin = Update.begin(contentLength);
                  if (canBegin) {
                      WiFiClient& tcp = http.getStream();
                      size_t written = Update.writeStream(tcp);
                      if (written == contentLength) {
                          Update.end();
                          
                          FirebaseJson successInbox;
                          successInbox.set("status", "⭐ OTA SUCCESS");
                          successInbox.set("message", "New firmware downloaded and installed. Rebooting!");
                          Firebase.RTDB.updateNode(&fbdo, "/AdminInbox/" + String(custom_dev_id), &successInbox);
                          delay(3000); 
                          ESP.restart();
                      } else {
                          FirebaseJson errInbox;
                          errInbox.set("status", "❌ OTA ERROR");
                          errInbox.set("message", "Download interrupted or file corrupted.");
                          Firebase.RTDB.updateNode(&fbdo, "/AdminInbox/" + String(custom_dev_id), &errInbox);
                          delay(3000); 
                          ESP.restart(); 
                      }
                  } else {
                      FirebaseJson errInbox;
                      errInbox.set("status", "❌ OTA ERROR");
                      errInbox.set("message", "Not enough free memory on ESP32 to install.");
                      Firebase.RTDB.updateNode(&fbdo, "/AdminInbox/" + String(custom_dev_id), &errInbox);
                      delay(3000); 
                      ESP.restart();
                  }
              } else {
                  FirebaseJson errInbox;
                  errInbox.set("status", "❌ OTA ERROR");
                  errInbox.set("message", "Bad Link! GitHub rejected it. HTTP Code: " + String(httpCode));
                  Firebase.RTDB.updateNode(&fbdo, "/AdminInbox/" + String(custom_dev_id), &errInbox);
                  delay(3000); 
                  ESP.restart(); 
              }
              http.end();
          }
      }
    }
    vTaskDelay(50 / portTICK_PERIOD_MS); 
  }
}

